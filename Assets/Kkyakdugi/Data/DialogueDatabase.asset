  - sequenceId: episode2_intro
    lines:
    - speaker: "\uAE85\uB450\uAE30"
      portraitKey: kkyak_happy
      text: "\uB124\uC78E\uD074\uB85C\uBC84\uB97C \uB2E4 \uCEA4\uC5B4\u2026.!!"
    - speaker: "\uAE85\uB450\uAE30"
      portraitKey: kkyak_happy
      text: "\uC774\uC81C \uB450\uD034\uBC8C\uB808\uB791 \uCC39\uB450\uB5A1\uC774\uB791
